# Direktaufruf von PHP-Dateien aus dem Browser sperren.
# Alle Requests laufen über public/.htaccess → server-php/index.php
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Nur interne Weiterleitungen (vom öffentlichen .htaccess) erlauben
    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteRule ^ - [F]
</IfModule>

# Datendateien immer sperren
<FilesMatch "\.(json|log|txt|env|lock)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
