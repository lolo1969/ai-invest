{
  "name": "vestia",
  "private": true,
  "version": "1.10.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && cp -r server-php dist/server-php && find dist/server-php/data -type f \\( -name '*.json' -o -name '*.log' -o -name '*.lock' -o -name '*.pid' \\) -delete 2>/dev/null; mkdir -p dist/server-php/data && touch dist/server-php/data/.gitkeep",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "php -S 0.0.0.0:3141 -t server-php server-php/router.php",
    "worker": "php server-php/worker.php",
    "server:start": "bash server-php/start.sh",
    "server:stop": "bash server-php/start.sh stop",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\" \"npm run worker\""
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.13.4",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  }
}
